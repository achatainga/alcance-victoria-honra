rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    // - Everyone can read basic profiles (needed for member linking)
    // - Only owner or Admin can write specific fields
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Members collection
    // - All authenticated users can READ (to see birthdays and for self-registration linking)
    // - Admins/Editors can CREATE/UPDATE/DELETE
    // - Users can CREATE/UPDATE their OWN record (via self-registration)
    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Allow self-registration
      allow update: if isAuthenticated(); // Allow updates for linking
      allow delete: if isAdmin();
    }

    // Honor Plans collection
    // - All authenticated users can READ active/planning plans
    // - Only admins can CREATE/UPDATE/DELETE
    match /honor_plans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Contributions collection
    // - All authenticated users can READ
    // - All authenticated users can CREATE (to contribute)
    // - Only admins can UPDATE/DELETE
    match /contributions/{contributionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Events collection (if exists)
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
